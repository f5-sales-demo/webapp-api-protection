# Copy to terraform.tfvars and adjust. terraform.tfvars is gitignored.
# Credentials are NOT set here — export XCSH_API_URL + XCSH_API_TOKEN in the
# environment (see terraform/README.md).

# F5 XC namespace for the load balancer and origin pool. Must already exist in
# the target tenant. Verified against the staging tenant's "r-mordasiewicz"
# namespace; change to your own.
namespace = "r-mordasiewicz"

# Domain the load balancer serves. Use one reachable in the target tenant.
lb_domain = "httpbin-webapp-tf.example.com"

# Origin: the public httpbin service (HTTP 200 on port 80, no redirect).
origin_dns_name = "httpbin.org"
origin_port     = 80

# HTTP path the origin-pool health check probes (httpbin /status/200 → 200).
health_check_path = "/status/200"

labels = {
  managed_by = "terraform"
  use_case   = "webapp-api-protection"
}
